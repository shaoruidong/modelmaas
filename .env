# ════════════════════════════════════════════════════════════════════════════
# MaaS 平台统一配置 — 修改此文件后执行 docker compose up -d --build
# ════════════════════════════════════════════════════════════════════════════

# ── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=django-change-this-secret-key-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── 数据库（容器内通过 maas-network 通信，DB_HOST 由 compose 覆盖为 maas-db）
DB_ENGINE=django.db.backends.mysql
DB_NAME=maas_db
DB_USER=root
DB_PASSWORD=MaasDB@2024Strong
DB_HOST=maas-db
DB_PORT=3306

# ── 跨域 ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5713

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=120
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
