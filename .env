# ════════════════════════════════════════════════════════════════════════════
# 本地开发调试配置
# 使用方式：cp .env.local .env  然后 cd maas-backend && python manage.py runserver
# 前提：本地已有 MySQL，或宿主机映射了 3307 端口（docker 的 maas-db）
# ════════════════════════════════════════════════════════════════════════════

# ── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=django-dev-insecure-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── 数据库（连接宿主机 MySQL，或 docker maas-db 映射出来的 3307）────────────
DB_ENGINE=django.db.backends.mysql
DB_NAME=maas_db
DB_USER=root
DB_PASSWORD=LcALua8@3yZHT7u2TRC.
DB_HOST=101.43.107.87
DB_PORT=3306

# ── 跨域（本地前端 vite dev server）─────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5713

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=120
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
