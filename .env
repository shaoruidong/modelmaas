# ════════════════════════════════════════════════════════════════════════════
# Docker 容器化部署配置
# 使用方式：cp .env.docker .env  然后 docker compose up -d --build
# ════════════════════════════════════════════════════════════════════════════

# ── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=django-change-this-secret-key-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,101.43.107.87

# ── 数据库（DB_HOST 由 docker-compose 覆盖为容器服务名 maas-db）────────────
DB_ENGINE=django.db.backends.mysql
DB_NAME=maas_db
DB_USER=root
DB_PASSWORD=MaasDB@2024Strong
DB_HOST=maas-db
DB_PORT=3306

# ── 跨域（填写服务器实际 IP 或域名）─────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5713,http://101.43.107.87:5713

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=120
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
